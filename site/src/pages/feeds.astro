---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { siteConfig } from "../config/site";

type FeedItem = {
  title: string;
  description: string;
  path: string;
  format: "RSS" | "iCal";
};

const feeds: FeedItem[] = [
  {
    title: "All Updates",
    description: "Combined feed with news, events, and podcast episodes.",
    path: "/rss.xml",
    format: "RSS",
  },
  {
    title: "News",
    description: "Official Bitcoin District news articles.",
    path: "/news/rss.xml",
    format: "RSS",
  },
  {
    title: "Events",
    description: "Bitcoin District events feed in RSS format.",
    path: "/events/rss.xml",
    format: "RSS",
  },
  {
    title: "Podcast",
    description: "Bitcoin District podcast episodes with audio enclosures.",
    path: "/podcast/rss.xml",
    format: "RSS",
  },
  {
    title: "Events Calendar",
    description: "Calendar subscription for events in iCalendar format.",
    path: "/events.ics",
    format: "iCal",
  },
];

const seo = {
  title: "Feeds | Bitcoin District",
  description: "Subscribe to Bitcoin District updates via RSS and iCal feeds.",
  canonical: "/feeds",
};
---

<Layout seo={seo}>
  <main class="feeds-page">
    <PageHeader
      title="Feeds"
      description="Subscribe to all updates or choose a specific feed for news, events, podcast, and calendar."
    />

    <section class="feeds-section" aria-labelledby="feeds-list-title">
      <h2 id="feeds-list-title" class="sr-only">Available feeds</h2>
      <ul class="feeds-grid">
        {feeds.map((feed) => (
          <li class="feed-card">
            <div class="feed-header">
              <h3>{feed.title}</h3>
              <span class:list={["feed-format", { "feed-format-ical": feed.format === "iCal" }]}>
                {feed.format}
              </span>
            </div>
            <p>{feed.description}</p>
            <a href={feed.path} class="feed-link" target="_blank" rel="noopener noreferrer">
              {new URL(feed.path, siteConfig.siteUrl).toString()}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>

<style>
  .feeds-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .feeds-section {
    margin-top: 2rem;
  }

  .feeds-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .feed-card {
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    padding: 1rem;
    background: #ffffff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .feed-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .feed-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #0e0535;
  }

  .feed-format {
    flex-shrink: 0;
    border: 1px solid rgba(14, 5, 53, 0.2);
    background: rgba(14, 5, 53, 0.08);
    color: #0e0535;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 999px;
    padding: 0.2rem 0.5rem;
  }

  .feed-format-ical {
    border-color: rgba(27, 94, 32, 0.25);
    background: rgba(27, 94, 32, 0.08);
    color: #1b5e20;
  }

  .feed-card p {
    margin: 0 0 0.85rem;
    color: rgba(0, 0, 0, 0.72);
    line-height: 1.55;
  }

  .feed-link {
    display: inline-block;
    color: #0e0535;
    font-size: 0.92rem;
    text-underline-offset: 2px;
    word-break: break-all;
  }

  .feed-link:hover {
    text-decoration-thickness: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .feeds-page {
      padding: 2.25rem 1rem;
    }
  }
</style>
