# Bitcoin District Production Site
# Caddy v2 configuration with automatic HTTPS

{
    # Global options
    email admin@bitcoindistrict.org
    # Caddy in Docker automatically uses /data for certificate storage
}

# Directus admin UI and API - subdomain approach (recommended by Directus)
cms.bitcoindistrict.org {
    # Automatic HTTPS via Let's Encrypt
    
    # Enable gzip compression
    encode gzip

    # Access logging
    log {
        output file /data/logs/cms-access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level INFO
    }

    # Handle preflight OPTIONS requests for assets (one block per allowed origin)
    @optionsBD method OPTIONS path /assets* header Origin https://bitcoindistrict.org
    handle @optionsBD {
        header Access-Control-Allow-Origin "https://bitcoindistrict.org"
        header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
        header Access-Control-Allow-Headers "Range"
        header Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
        header Vary "Origin"
        respond 204
    }

    @optionsBDI method OPTIONS path /assets* header Origin https://bitcoindistrictinitiative.org
    handle @optionsBDI {
        header Access-Control-Allow-Origin "https://bitcoindistrictinitiative.org"
        header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
        header Access-Control-Allow-Headers "Range"
        header Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
        header Vary "Origin"
        respond 204
    }

    # Handle GET/HEAD requests for assets with CORS headers
    handle /assets* {
        # Set CORS origin dynamically based on the requesting origin
        @fromBD header Origin https://bitcoindistrict.org
        header @fromBD Access-Control-Allow-Origin "https://bitcoindistrict.org"

        @fromBDI header Origin https://bitcoindistrictinitiative.org
        header @fromBDI Access-Control-Allow-Origin "https://bitcoindistrictinitiative.org"

        header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
        header Access-Control-Allow-Headers "Range"
        header Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
        header Vary "Origin"

        reverse_proxy http://directus:8055 {
            header_down Cache-Control "public, max-age=31536000, immutable"
            header_down X-Content-Type-Options "nosniff"

            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # Proxy to Directus container (use container name, not localhost)
    handle {
        reverse_proxy http://directus:8055 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
            
            transport http {
                dial_timeout 10s
                response_header_timeout 60s
            }
        }
    }
}

bitcoindistrict.org {
    # Automatic HTTPS via Let's Encrypt (email configured globally above)
    
    # Enable gzip compression
    encode gzip

    # Access logging with rotation
    log {
        output file /data/logs/access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level INFO
    }

    # Directus assets - proxy to directus container
    # FIX: Use 'handle' (NOT handle_path) so Directus receives the '/assets' prefix
    handle /assets* {
        # Standardize Cache for mobile performance
        header Cache-Control "public, max-age=31536000, immutable"
        
        reverse_proxy http://directus:8055 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            
            # Ensure Range headers are respected for iOS audio/video
            header_down +Accept-Ranges "bytes"
        }
    }

    # Main Astro site - proxy to astro container
    handle {
        reverse_proxy http://astro:4321 {
            # Forward real client information
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
            
            # Health check
            health_uri /
            health_interval 30s
            health_timeout 5s
            
            # Timeouts
            transport http {
                dial_timeout 10s
                response_header_timeout 30s
            }
        }
    }

    # Security headers
    header {
        # HSTS (HTTP Strict Transport Security)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        
        # XSS Protection
        X-XSS-Protection "1; mode=block"
        
        # Referrer Policy
        Referrer-Policy "strict-origin-when-cross-origin"
        
        # Permissions Policy (formerly Feature Policy)
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        
        # Remove server identification
        -Server
    }

    # Error pages
    handle_errors {
        @5xx expression `{err.status_code} >= 500 && {err.status_code} < 600`
        handle @5xx {
            respond "Service temporarily unavailable. Please try again later." 503
        }
        
        @4xx expression `{err.status_code} >= 400 && {err.status_code} < 500`
        handle @4xx {
            respond "The requested resource was not found." 404
        }
    }
}

# Bitcoin District Initiative - SSR site
bitcoindistrictinitiative.org {
    encode gzip

    log {
        output file /data/logs/bdi-access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level INFO
    }

    # BDI Astro SSR site
    handle {
        reverse_proxy http://bdi-astro:4322 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}

            health_uri /
            health_interval 30s
            health_timeout 5s

            transport http {
                dial_timeout 10s
                response_header_timeout 30s
            }
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    handle_errors {
        @5xx expression `{err.status_code} >= 500 && {err.status_code} < 600`
        handle @5xx {
            respond "Service temporarily unavailable." 503
        }
        @4xx expression `{err.status_code} >= 400 && {err.status_code} < 500`
        handle @4xx {
            respond "Not found." 404
        }
    }
}

